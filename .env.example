# Qwopus-Agent runtime configuration
#
# Keep model weights outside this repository, for example under:
# ~/Desktop/model/gemma-4-12B-it-qat-OptiQ-4bit

QWOPUS_LLM_PROVIDER=local_mlx
QWOPUS_MLX_BASE_URL=http://127.0.0.1:8080/v1
QWOPUS_MLX_MODEL=gemma-4-12B-it-qat-OptiQ-4bit

# smolagents local model bridge
QWOPUS_SMOLAGENTS_API_KEY=local_token
QWOPUS_SMOLAGENTS_TIMEOUT_SECONDS=120
QWOPUS_SMOLAGENTS_TEMPERATURE=0.2
QWOPUS_SMOLAGENTS_MAX_TOKENS=1024
